    <PackageReference Include="VirtoCommerce.MarketingModule.Core" Version="3.824.0-alpha.902-vcst-4203-cleanup" />
    <PackageReference Include="VirtoCommerce.PaymentModule.Core" Version="3.811.0-alpha.257-vcst-4203-cleanup" />
    <PackageReference Include="VirtoCommerce.PricingModule.Core" Version="3.822.0-alpha.781-vcst-4203-cleanup" />
    <PackageReference Include="VirtoCommerce.ShippingModule.Core" Version="3.816.0-alpha.232-vcst-4203-cleanup" />
    <PackageReference Include="VirtoCommerce.Xapi.Core" Version="3.928.0-alpha.130-vcst-4203-cleanup" />
    <PackageReference Include="VirtoCommerce.XCatalog.Core" Version="3.942.0-alpha.157-vcst-4203-cleanup" />
